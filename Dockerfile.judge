FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    gcc \
    g++ \
    golang-go \
    nodejs \
    npm \
    openjdk-17-jdk-headless \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g typescript ts-node

WORKDIR /tmp/work

CMD ["sh", "-lc", "sleep infinity"]
