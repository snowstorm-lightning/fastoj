# Copy to .env for local development. Do not commit real secrets.

# Docker Compose database defaults. Change these before any real deployment.
POSTGRES_DB=fastoj
POSTGRES_USER=fastoj
POSTGRES_PASSWORD=fastoj_secret
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5433
REDIS_BIND=127.0.0.1
REDIS_PORT=6379
FASTOJ_BIND=127.0.0.1
FASTOJ_PORT=8010

# Direct host backend development uses the Compose-published PostgreSQL port.
# Docker Compose containers override DATABASE_URL to use postgres:5432.
DATABASE_URL=postgresql://fastoj:fastoj_secret@localhost:5433/fastoj
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=true

# For list settings, use JSON syntax when setting through environment variables.
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8010"]

# AI is disabled unless this is set to openai_compatible.
AI_PROVIDER=disabled

# DeepSeek API mode:
# AI_PROVIDER=openai_compatible
# AI_BASE_URL=https://api.deepseek.com
# AI_API_KEY=replace-with-your-deepseek-api-key
# AI_MODEL=deepseek-v4-flash
#
# Optional named DeepSeek profile used by the in-page model selector.
# AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
# AI_DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
# AI_DEEPSEEK_MODEL=deepseek-v4-flash

# Local OpenAI-compatible model mode, for example llama.cpp:
# AI_PROVIDER=openai_compatible
# AI_BASE_URL=http://localhost:8080/v1
# AI_API_KEY=sk-no-key-required
# AI_MODEL=qwen2.5-coder-7b-instruct-q4_k_m
#
# Optional named Qwen local profile used by the in-page model selector.
# In Docker Compose, containers should call the host service through host.docker.internal.
# AI_QWEN_BASE_URL=http://host.docker.internal:8080/v1
# AI_QWEN_API_KEY=sk-no-key-required
# AI_QWEN_MODEL=qwen2.5-coder-7b-instruct-q4_k_m

# Docker Compose reads this .env file for variable substitution.
# For a local model called from containers, use:
# AI_BASE_URL=http://host.docker.internal:8080/v1
